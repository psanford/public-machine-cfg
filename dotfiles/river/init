#!/bin/sh

export PATH=$PATH:/home/psanford/bin

# Start the window manager.
weir -log-level debug 2>/tmp/weir.log &

# Give it a moment to take the window manager role and open its control
# socket before configuring it.
weirctl wait-for-socket

# --- appearance -------------------------------------------------------------
weirctl set border-width 2
weirctl set border-color-focused   0x93a1a1
weirctl set border-color-unfocused 0x586e75
#weirctl set gaps 2 2
#weirctl set smart-gaps on

# --- layout -----------------------------------------------------------------
weirctl set main-ratio 0.6
weirctl set main-location left
# weirctl workspace-mode locked     # uncomment for gnome-style workspaces

# --- key bindings (xmonad-flavored) ----------------------------------------
mod=Super

weirctl bind $mod+Shift+Return        spawn 'foot'
weirctl bind $mod+p             spawn 'rofi -show run'
weirctl bind $mod+Shift+c       close
weirctl bind $mod+Shift+q       exit

weirctl bind $mod+j             focus next
weirctl bind $mod+k             focus prev
weirctl bind $mod+m             focus main
weirctl bind $mod+Shift+j       swap next
weirctl bind $mod+Shift+k       swap prev
weirctl bind $mod+Return        zoom

weirctl bind $mod+h             set main-ratio -0.05
weirctl bind $mod+l             set main-ratio +0.05
weirctl bind $mod+comma         set main-count +1
weirctl bind $mod+period        set main-count -1
weirctl bind $mod+space         cycle-layout monocle,left,top
weirctl bind $mod+Shift+space   set-layout tile

weirctl bind $mod+t             toggle-float
weirctl bind $mod+f             toggle-fullscreen

weirctl bind $mod+w             focus-output left
weirctl bind $mod+e             focus-output right
weirctl bind $mod+Shift+w       send-to-output left
weirctl bind $mod+Shift+e       send-to-output right

# Workspaces 1-9: view with $mod+N, send with $mod+Shift+N.
for i in 1 2 3 4 5 6 7 8 9; do
    weirctl bind $mod+$i view $i
    weirctl bind $mod+Shift+$i send $i
done

weirctl bind Control+Alt+Left view prev
weirctl bind Control+Alt+Right view next


weirctl bind Control+Alt+Backspace exit

weirctl bind Control+Alt+l spawn "swaylock --daemonize --show-failed-attempts --indicator-idle-visible  --color 121b26 -t"

# --- pointer bindings -------------------------------------------------------
weirctl bind-pointer $mod+Left  move
weirctl bind-pointer $mod+Right resize

weirctl  input 'Apple MTP multi-touch' natural-scroll disabled

weirctl set focus-follows-cursor on


# Media keys work without a modifier.
weirctl bind None+XF86AudioRaiseVolume  spawn 'wpctl set-volume -l 1.4 @DEFAULT_AUDIO_SINK@ 5%+'
weirctl bind None+XF86AudioLowerVolume  spawn 'wpctl set-volume -l 1.4 @DEFAULT_AUDIO_SINK@ 5%-'
weirctl bind None+XF86AudioMute         spawn 'wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle'
weirctl bind None+XF86MonBrightnessUp   spawn 'brightnessctl set +5%'
weirctl bind None+XF86MonBrightnessDown spawn 'brightnessctl set 5%-'


# set non-ugly cursor theme and size
weirctl set xcursor-theme Adwaita 24




# # Super+Period and Super+Comma to focus the next/previous output
# ctlriver map normal Super Period focus-output next
# ctlriver map normal Super Comma focus-output previous

# # Super+Shift+{Period,Comma} to send the focused view to the next/previous output
# ctlriver map normal Super+Shift Period send-to-output next
# ctlriver map normal Super+Shift Comma send-to-output previous

# # Super+Shift+H and Super+Shift+L to increment/decrement the main count of rivertile(1)
# ctlriver map normal Super+Shift H send-layout-cmd $LAYOUTMGR "main-count +1"
# ctlriver map normal Super+Shift L send-layout-cmd $LAYOUTMGR "main-count -1"


# # Super+Alt+{H,J,K,L} to move views
# ctlriver map normal Super+Alt H move left 100
# ctlriver map normal Super+Alt J move down 100
# ctlriver map normal Super+Alt K move up 100
# ctlriver map normal Super+Alt L move right 100

# # Super+Alt+Control+{H,J,K,L} to snap views to screen edges
# ctlriver map normal Super+Alt+Control H snap left
# ctlriver map normal Super+Alt+Control J snap down
# ctlriver map normal Super+Alt+Control K snap up
# ctlriver map normal Super+Alt+Control L snap right

# # Super+Alt+Shift+{H,J,K,L} to resize views
# ctlriver map normal Super+Alt+Shift H resize horizontal -100
# ctlriver map normal Super+Alt+Shift J resize vertical 100
# ctlriver map normal Super+Alt+Shift K resize vertical -100
# ctlriver map normal Super+Alt+Shift L resize horizontal 100

# # Super+T toggles float
# ctlriver map normal Super T toggle-float

# Super+{Up,Right,Down,Left} to change layout orientation
#ctlriver map normal Super Up    send-layout-cmd $LAYOUTMGR "main-location top"
#ctlriver map normal Super Right send-layout-cmd $LAYOUTMGR "main-location right"
#ctlriver map normal Super Down  send-layout-cmd $LAYOUTMGR "main-location bottom"
#ctlriver map normal Super Left  send-layout-cmd $LAYOUTMGR "main-location left"

# # Declare a passthrough mode. This mode has only a single mapping to return to
# # normal mode. This makes it useful for testing a nested wayland compositor
# ctlriver declare-mode passthrough

# # Super+F11 to enter passthrough mode
# ctlriver map normal Super F11 enter-mode passthrough

# # Super+F11 to return to normal mode
# ctlriver map passthrough Super F11 enter-mode normal

# # Set background and border color
# ctlriver background-color 0x002b36
# ctlriver border-color-focused 0x93a1a1
# ctlriver border-color-unfocused 0x586e75

# # Set keyboard repeat rate
# ctlriver set-repeat 50 300

# # force emacs to have boarder decorations
# ctlriver rule-add -app-id "emacs" ssd

################################################################################

source $HOME/.config/river/$HOSTNAME

################################################################################

# needed for gnome-keyring to work
dbus-update-activation-environment --systemd DISPLAY XAUTHORITY WAYLAND_DISPLAY

# needed for xdg-desktop-portal-wlr to work properly
dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=river

# needed for systemd services like awsso-agent
systemctl --user import-environment DISPLAY WAYLAND_DISPLAY XAUTHORITY DBUS_SESSION_BUS_ADDRESS
# trigger 'graphical-session.target' for systemd user units waiting for it
systemctl --user start graphical-session.target

eww daemon
until eww ping >/dev/null 2>&1; do sleep 0.1; done
eww open bar

gnome-keyring-daemon &
swayidle -w &
pasystray &
nm-applet &
blueman-applet &
dunst &
