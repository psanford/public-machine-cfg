#!/bin/sh
# JSON: {"present":true,"capacity":85,"status":"Charging"}
# Reads sysfs directly so it works with any battery name (BAT0, BAT1,
# macsmc-battery on Apple Silicon, ...).
for cap in /sys/class/power_supply/*/capacity; do
    [ -r "$cap" ] || continue
    dir=$(dirname "$cap")
    printf '{"present":true,"capacity":%s,"status":"%s"}\n' \
        "$(cat "$cap")" "$(cat "$dir/status" 2>/dev/null || echo Unknown)"
    exit 0
done
echo '{"present":false,"capacity":0,"status":"none"}'
