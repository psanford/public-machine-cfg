#!/bin/sh
# JSON: {"ssid":"mynetwork","signal":85}
command -v nmcli >/dev/null 2>&1 || { echo '{"ssid":"","signal":0}'; exit 0; }
line=$(nmcli -t -f active,ssid,signal dev wifi list 2>/dev/null | grep '^yes:' | head -1)
if [ -n "$line" ]; then
    printf '{"ssid":"%s","signal":%s}\n' \
        "$(echo "$line" | cut -d: -f2)" "$(echo "$line" | cut -d: -f3 | grep -E '^[0-9]+$' || echo 0)"
else
    echo '{"ssid":"","signal":0}'
fi
