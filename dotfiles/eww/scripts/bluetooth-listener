#!/bin/sh
# Kill the whole process group on exit so background helpers (monitors,
# tick loops) never outlive this script when eww reloads or restarts.
trap 'trap - TERM; kill 0' INT TERM EXIT
# Stream bluetooth state as JSON: {"powered":"on","connected":1}
# Event-driven via bluez dbus signals (instant on connect/power changes)
# merged with a 120s tick as a safety net. Falls back to pure 120s polling
# if dbus-monitor is unavailable.
get() {
    if bluetoothctl show 2>/dev/null | grep -q "Powered: yes"; then p=on; else p=off; fi
    c=$(bluetoothctl devices Connected 2>/dev/null | grep -c "^Device")
    printf '{"powered":"%s","connected":%s}\n' "$p" "${c:-0}"
}
command -v bluetoothctl >/dev/null 2>&1 || { echo '{"powered":"off","connected":0}'; exit 0; }
get
if command -v dbus-monitor >/dev/null 2>&1; then
    ( dbus-monitor --system "type='signal',sender='org.bluez'" 2>/dev/null & \
      while :; do sleep 120; echo tick; done ) \
        | grep --line-buffered -E "tick|PropertiesChanged|InterfacesAdded|InterfacesRemoved" \
        | while read -r _; do get; done
else
    while :; do sleep 120; get; done
fi
